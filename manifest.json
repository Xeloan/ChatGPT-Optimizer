{
  "manifest_version": 3,
  "name": "ChatGPT 聊天性能优化",
  "version": "1.0",
  "description": "优化长对话渲染，基本无感，性能提升明显，大幅减少卡顿（模型卡的话莫得办法）",
  "browser_specific_settings": {
    "gecko": {
      "id": "chatgpt-performance@xeloan.dev"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
  "16": "icon16.png",
  "48": "icon48.png",
  "128": "icon128.png"
  }
}